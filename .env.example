# Environment Configuration
# Copy this file to .env and fill in the required values

# ─── Application ──────────────────────────────────────────────────────────────
NODE_ENV=development

# ─── Backend ──────────────────────────────────────────────────────────────────
BACKEND_PORT=3000

# ─── Frontend ─────────────────────────────────────────────────────────────────
FRONTEND_PORT=3001
FRONTEND_URL=http://localhost:3001

# URL of the API as seen by the browser (used to build the SDK client)
VITE_BACKEND_API_URL=http://localhost:3000

# ─── Database ─────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_DATABASE=myapp
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_SSL=false

# ─── Security ─────────────────────────────────────────────────────────────────
JWT_SECRET=your_jwt_secret_here

# Set to true in production (requires HTTPS)
COOKIE_SECURE=false
# Domain for auth cookies — use your root domain in production (e.g. example.com)
COOKIE_DOMAIN=localhost

# ─── External APIs ────────────────────────────────────────────────────────────
TMDB_API_KEY=your_tmdb_api_key_here

# ─── Email (Mailgun) ──────────────────────────────────────────────────────────
# Leave MAILGUN_API_KEY empty in development — emails will be logged to console instead
MAILGUN_API_KEY=
MAILGUN_API_URL=mg.yourdomain.com
MAILGUN_BASE_URL=https://api.eu.mailgun.net

# ─── Production only ──────────────────────────────────────────────────────────
# SENTRY_AUTH_TOKEN=   # Used by CI/CD for Sentry source map uploads
